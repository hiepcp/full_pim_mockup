            <!-- Step 2: In Review — CURRENT -->
            <div class="flex gap-3 pb-4 relative">
              <div class="flex flex-col items-center">
                <div class="w-6 h-6 rounded-full bg-brand-600 flex items-center justify-center shrink-0 z-10 relative pulse-dot">
                  <i class="ti ti-eye text-white text-xs"></i>
                </div>
                <div class="w-px flex-1 bg-stone-200 mt-1"></div>
              </div>
              <div class="pt-0.5 pb-1 flex-1">
                <div class="flex items-center gap-1.5">
                  <span class="text-xs font-semibold text-brand-600">In Review</span>
                  <span class="text-[10px] bg-brand-600 text-white rounded px-1 py-0.5 font-medium">NOW</span>
                </div>
                <div class="text-[11px] text-stone-500 mt-0.5">Assigned: Product &amp; Design Team</div>
                <div class="mt-1.5 bg-brand-50 border border-brand-100 rounded-md px-2 py-1.5">
                  <div class="text-[11px] text-brand-700 font-medium">Pending review by:</div>
                  <div class="text-[11px] text-stone-600 mt-0.5">· Erik O. (Product Design Lead)</div>
                  <div class="text-[11px] text-stone-600">· Lars V. (Technical Compliance)</div>
                  <div class="text-[11px] text-amber-700 mt-1">Retailer John Lewis sign-off required</div>
                </div>
              </div>
            </div>

            <!-- Step 3: Approve pending -->
            <div class="flex gap-3 pb-4 relative">
              <div class="flex flex-col items-center">
                <div class="w-6 h-6 rounded-full bg-stone-200 flex items-center justify-center shrink-0 z-10 relative">
                  <i class="ti ti-circle text-stone-400 text-xs"></i>
                </div>
                <div class="w-px flex-1 bg-stone-200 mt-1"></div>
              </div>
              <div class="pt-0.5 pb-1">
                <div class="text-xs font-medium text-stone-400">Approve — Design &amp; Compliance</div>
                <div class="text-[11px] text-stone-300 mt-0.5">Pending</div>
              </div>
            </div>

            <!-- Step 4: Approved / Publish -->
            <div class="flex gap-3">
              <div class="flex flex-col items-center">
                <div class="w-6 h-6 rounded-full bg-stone-200 flex items-center justify-center shrink-0">
                  <i class="ti ti-send text-stone-400 text-xs"></i>
