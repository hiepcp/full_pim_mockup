<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document Hub — PIM Studio</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Outfit', 'system-ui', 'sans-serif'] },
          colors: {
            brand: { 50:'#E6F1FB', 100:'#CCDFF7', 400:'#378ADD', 600:'#185FA5', 800:'#0C447C' },
          },
          boxShadow: {
            card: '0 1px 4px rgba(24,95,165,0.06)',
            hover: '0 4px 14px rgba(24,95,165,0.10)',
            doc:  '0 8px 32px rgba(0,0,0,0.18)',
          },
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.31.0/dist/tabler-icons.min.css">
  <style>
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes pulse-ring {
      0%   { box-shadow: 0 0 0 0 rgba(24,95,165,0.35); }
      70%  { box-shadow: 0 0 0 6px rgba(24,95,165,0); }
      100% { box-shadow: 0 0 0 0 rgba(24,95,165,0); }
    }
    @keyframes fillBar {
      from { width: 0; }
    }
    @keyframes pageFlip {
      0%   { transform: perspective(400px) rotateY(0deg); }
      50%  { transform: perspective(400px) rotateY(-8deg); }
      100% { transform: perspective(400px) rotateY(0deg); }
    }
    .pulse-dot { animation: pulse-ring 1.8s ease-out infinite; }
    .fill-bar  { animation: fillBar 0.9s cubic-bezier(.22,.68,0,1.2) both; }
    body { font-family: 'Outfit', system-ui, sans-serif; }
    .tabular { font-variant-numeric: tabular-nums; }
    .doc-shadow { filter: drop-shadow(0 8px 20px rgba(0,0,0,0.22)); }
    .page-hover:hover { transform: perspective(600px) rotateY(-4deg) translateY(-2px); transition: transform 0.3s ease; }
  </style>
</head>
<body class="bg-stone-100 text-stone-800 antialiased">

<!-- SIDEBAR -->
<aside class="w-[200px] shrink-0 bg-white border-r border-black/10 fixed top-0 left-0 h-screen overflow-y-auto flex flex-col z-10">
  <div class="px-4 py-[18px] border-b border-black/10">
    <div class="text-sm font-semibold text-stone-900">PIM Studio</div>
    <div class="text-[11px] text-stone-500 mt-0.5">Product Info Management</div>
  </div>
  <nav class="py-2 flex-1">
    <div class="text-[10px] font-medium text-stone-400 uppercase tracking-widest px-3.5 pt-3.5 pb-1">Catalogue</div>
    <a href="products.html"       class="nav-item flex items-center gap-2 px-3.5 py-1.5 text-[13px] text-stone-500 border-l-2 border-transparent hover:bg-stone-50 hover:text-stone-900 transition-colors"><i class="ti ti-box text-base"></i> Products</a>
    <a href="product-sets.html"   class="nav-item flex items-center gap-2 px-3.5 py-1.5 text-[13px] text-stone-500 border-l-2 border-transparent hover:bg-stone-50 hover:text-stone-900 transition-colors"><i class="ti ti-components text-base"></i> Product Sets</a>
    <a href="materials.html" class="flex items-center gap-2 px-3.5 py-1.5 text-[13px] text-stone-500 border-l-2 border-transparent hover:bg-stone-50 hover:text-stone-900 transition-colors"><i class="ti ti-color-swatch text-base"></i> Materials</a>
    <div class="text-[10px] font-medium text-stone-400 uppercase tracking-widest px-3.5 pt-3.5 pb-1">Assets</div>
    <a href="image-engine.html"   class="nav-item flex items-center gap-2 px-3.5 py-1.5 text-[13px] text-stone-500 border-l-2 border-transparent hover:bg-stone-50 hover:text-stone-900 transition-colors"><i class="ti ti-photo text-base"></i> Image Engine</a>
    <a href="document-hub.html"   class="nav-item flex items-center gap-2 px-3.5 py-1.5 text-[13px] text-brand-600 bg-brand-50 border-l-2 border-brand-600 font-medium"><i class="ti ti-file-stack text-base"></i> Document Hub</a>
    <div class="text-[10px] font-medium text-stone-400 uppercase tracking-widest px-3.5 pt-3.5 pb-1">Publishing</div>
    <a href="social-campaign.html" class="nav-item flex items-center gap-2 px-3.5 py-1.5 text-[13px] text-stone-500 border-l-2 border-transparent hover:bg-stone-50 hover:text-stone-900 transition-colors"><i class="ti ti-speakerphone text-base"></i> Social Campaign</a>
    <a href="publish-flow.html"   class="nav-item flex items-center gap-2 px-3.5 py-1.5 text-[13px] text-stone-500 border-l-2 border-transparent hover:bg-stone-50 hover:text-stone-900 transition-colors"><i class="ti ti-send text-base"></i> Publish Flow</a>
    <div class="text-[10px] font-medium text-stone-400 uppercase tracking-widest px-3.5 pt-3.5 pb-1">System</div>
    <a href="settings.html"       class="nav-item flex items-center gap-2 px-3.5 py-1.5 text-[13px] text-stone-500 border-l-2 border-transparent hover:bg-stone-50 hover:text-stone-900 transition-colors"><i class="ti ti-settings text-base"></i> Settings</a>
  </nav>
  <div class="px-4 py-3 border-t border-black/10">
    <div class="flex items-center gap-2">
      <div class="w-6 h-6 rounded-full bg-brand-100 flex items-center justify-center text-brand-600 text-[10px] font-bold">HC</div>
      <div>
        <div class="text-[11px] font-medium text-stone-800">Hugo Claes</div>
        <div class="text-[10px] text-stone-400">Admin</div>
      </div>
    </div>
  </div>
</aside>

<!-- MAIN LAYOUT -->
<div class="ml-[200px] min-h-screen flex flex-col">

  <!-- TOPBAR -->
  <header class="sticky top-0 z-10 bg-white border-b border-black/10 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-1.5 text-sm">
      <span class="text-stone-400">Assets</span>
      <i class="ti ti-chevron-right text-stone-300 text-xs"></i>
      <span class="font-semibold text-stone-800">Document Hub</span>
    </div>
    <div class="flex items-center gap-2">
      <button class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-stone-600 bg-stone-100 border border-black/10 rounded-lg hover:bg-stone-200 transition-all hover:-translate-y-px active:scale-[0.98]">
        <i class="ti ti-filter text-sm"></i> Filter
      </button>
      <button class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-white bg-brand-600 rounded-lg hover:bg-brand-800 transition-all hover:-translate-y-px active:scale-[0.98] shadow-sm">
        <i class="ti ti-upload text-sm"></i> Upload Document
      </button>
      <div class="w-px h-5 bg-black/10 mx-1"></div>
      <button class="w-7 h-7 flex items-center justify-center rounded-lg text-stone-500 hover:bg-stone-100 transition-colors relative">
        <i class="ti ti-bell text-base"></i>
        <span class="absolute top-1 right-1 w-1.5 h-1.5 bg-red-400 rounded-full"></span>
      </button>
    </div>
  </header>

  <!-- PAGE CONTENT -->
  <main class="flex-1 p-6 space-y-5">

    <!-- PAGE HEADING -->
    <div style="animation: fadeUp 0.25s ease both; animation-delay: 0s">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-lg font-bold text-stone-900">Document Hub</h1>
          <p class="text-xs text-stone-500 mt-0.5">Assembly Instructions, Care Guides, Technical Datasheets, Compliance Certificates, Material Safety Data Sheets &amp; more — version-controlled with approval workflow.</p>
        </div>
        <div class="flex items-center gap-1.5 text-[11px] text-amber-700 bg-amber-50 border border-amber-200 rounded-md px-2.5 py-1">
          <i class="ti ti-info-circle text-sm"></i>
          Only <strong>Approved</strong> documents can be shared or published. No hard delete — all versions retained.
        </div>
      </div>
    </div>

    <!-- STATS ROW -->
    <div class="grid grid-cols-4 gap-4" style="animation: fadeUp 0.25s ease both; animation-delay: 0.05s">

      <div class="bg-white rounded-xl border border-black/10 shadow-card hover:shadow-hover hover:-translate-y-px transition-all duration-200 px-5 py-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-medium text-stone-500">Total Documents</span>
          <div class="w-7 h-7 rounded-lg bg-stone-50 flex items-center justify-center">
            <i class="ti ti-files text-sm text-stone-500"></i>
          </div>
        </div>
        <div class="tabular text-2xl font-bold text-stone-900">47</div>
        <div class="text-[11px] text-stone-400 mt-0.5">Across all types</div>
        <div class="mt-3 h-1 bg-stone-100 rounded-full overflow-hidden">
          <div class="fill-bar h-1 bg-stone-300 rounded-full" style="width:100%; animation-delay:0.3s"></div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-black/10 shadow-card hover:shadow-hover hover:-translate-y-px transition-all duration-200 px-5 py-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-medium text-stone-500">Approved</span>
          <div class="w-7 h-7 rounded-lg bg-emerald-50 flex items-center justify-center">
            <i class="ti ti-circle-check text-sm text-emerald-500"></i>
          </div>
        </div>
        <div class="tabular text-2xl font-bold text-emerald-600">31</div>
        <div class="text-[11px] text-stone-400 mt-0.5">Ready to use</div>
        <div class="mt-3 h-1 bg-stone-100 rounded-full overflow-hidden">
          <div class="fill-bar h-1 bg-emerald-400 rounded-full" style="width:66%; animation-delay:0.35s"></div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-black/10 shadow-card hover:shadow-hover hover:-translate-y-px transition-all duration-200 px-5 py-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-medium text-stone-500">Pending Review</span>
          <div class="w-7 h-7 rounded-lg bg-brand-50 flex items-center justify-center">
            <i class="ti ti-clock text-sm text-brand-600"></i>
          </div>
        </div>
        <div class="tabular text-2xl font-bold text-brand-600">9</div>
        <div class="text-[11px] text-stone-400 mt-0.5">Awaiting approval</div>
        <div class="mt-3 h-1 bg-stone-100 rounded-full overflow-hidden">
          <div class="fill-bar h-1 bg-brand-400 rounded-full" style="width:19%; animation-delay:0.4s"></div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-black/10 shadow-card hover:shadow-hover hover:-translate-y-px transition-all duration-200 px-5 py-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-medium text-stone-500">Draft</span>
          <div class="w-7 h-7 rounded-lg bg-stone-50 flex items-center justify-center">
            <i class="ti ti-pencil text-sm text-stone-400"></i>
          </div>
        </div>
        <div class="tabular text-2xl font-bold text-stone-500">7</div>
        <div class="text-[11px] text-stone-400 mt-0.5">Work in progress</div>
        <div class="mt-3 h-1 bg-stone-100 rounded-full overflow-hidden">
          <div class="fill-bar h-1 bg-stone-300 rounded-full" style="width:15%; animation-delay:0.45s"></div>
        </div>
      </div>
    </div>

    <!-- FILTER TABS + SEARCH -->
    <div class="flex items-center justify-between" style="animation: fadeUp 0.25s ease both; animation-delay: 0.1s">
      <div class="flex items-center gap-1 bg-white rounded-lg border border-black/10 p-1">
        <button onclick="setTab(this,'all')"            data-tab="all"           class="tab-btn px-3 py-1 text-xs font-medium rounded-md bg-brand-600 text-white transition-all">All <span class="tabular ml-1 opacity-70">47</span></button>
        <button onclick="setTab(this,'assembly')"       data-tab="assembly"      class="tab-btn px-3 py-1 text-xs font-medium rounded-md text-stone-500 hover:text-stone-800 hover:bg-stone-50 transition-all">Assembly</button>
        <button onclick="setTab(this,'careguide')"      data-tab="careguide"     class="tab-btn px-3 py-1 text-xs font-medium rounded-md text-stone-500 hover:text-stone-800 hover:bg-stone-50 transition-all">Care Guide</button>
        <button onclick="setTab(this,'datasheet')"      data-tab="datasheet"     class="tab-btn px-3 py-1 text-xs font-medium rounded-md text-stone-500 hover:text-stone-800 hover:bg-stone-50 transition-all">Datasheet</button>
        <button onclick="setTab(this,'bom')"            data-tab="bom"           class="tab-btn px-3 py-1 text-xs font-medium rounded-md text-stone-500 hover:text-stone-800 hover:bg-stone-50 transition-all">BOM</button>
        <button onclick="setTab(this,'testreport')"     data-tab="testreport"    class="tab-btn px-3 py-1 text-xs font-medium rounded-md text-stone-500 hover:text-stone-800 hover:bg-stone-50 transition-all">Test Report</button>
        <button onclick="setTab(this,'certification')"  data-tab="certification" class="tab-btn px-3 py-1 text-xs font-medium rounded-md text-stone-500 hover:text-stone-800 hover:bg-stone-50 transition-all">Certification</button>
        <button onclick="setTab(this,'msds')"           data-tab="msds"          class="tab-btn px-3 py-1 text-xs font-medium rounded-md text-stone-500 hover:text-stone-800 hover:bg-stone-50 transition-all">MSDS</button>
      </div>
      <div class="flex items-center gap-2">
        <div class="relative">
          <i class="ti ti-search absolute left-2.5 top-1/2 -translate-y-1/2 text-stone-400 text-sm"></i>
          <input type="text" placeholder="Search documents..." class="pl-8 pr-3 py-1.5 text-xs border border-black/10 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-brand-400/30 focus:border-brand-400 w-52 transition-all">
        </div>
        <button class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-stone-600 bg-white border border-black/10 rounded-lg hover:bg-stone-50 transition-all">
          <i class="ti ti-sort-ascending text-sm"></i> Sort
        </button>
        <button class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-stone-600 bg-white border border-black/10 rounded-lg hover:bg-stone-50 transition-all">
          <i class="ti ti-layout-columns text-sm"></i> View
        </button>
      </div>
    </div>

    <!-- MAIN TABLE + SIDE PANEL -->
    <div class="flex gap-4" style="animation: fadeUp 0.25s ease both; animation-delay: 0.15s">

      <!-- DOCUMENT TABLE -->
      <div class="flex-1 bg-white rounded-xl border border-black/10 shadow-card overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-black/10 bg-stone-50">
                <th class="text-left px-4 py-2.5 font-semibold text-stone-600 w-8">
                  <input type="checkbox" class="rounded border-black/20 w-3.5 h-3.5">
                </th>
                <th class="text-left px-4 py-2.5 font-semibold text-stone-600">Document</th>
                <th class="text-left px-4 py-2.5 font-semibold text-stone-600">Type</th>
                <th class="text-left px-4 py-2.5 font-semibold text-stone-600">Product / Item</th>
                <th class="text-left px-4 py-2.5 font-semibold text-stone-600 tabular">Version</th>
                <th class="text-left px-4 py-2.5 font-semibold text-stone-600">Status</th>
                <th class="text-left px-4 py-2.5 font-semibold text-stone-600">Author</th>
                <th class="text-left px-4 py-2.5 font-semibold text-stone-600">Updated</th>
                <th class="text-left px-4 py-2.5 font-semibold text-stone-600">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-black/[0.05]">

              <!-- Row 1: Assembly Instruction Lounge Chair -->
              <tr class="hover:bg-stone-50 transition-colors cursor-pointer" onclick="selectRow(this)">
                <td class="px-4 py-3"><input type="checkbox" class="rounded border-black/20 w-3.5 h-3.5"></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2.5">
                    <div class="w-7 h-7 rounded-lg bg-amber-50 flex items-center justify-center shrink-0">
                      <i class="ti ti-tool text-sm text-amber-600"></i>
                    </div>
                    <div>
                      <div class="font-medium text-stone-800">Assembly Instruction — Forma Lounge Chair</div>
                      <div class="text-[11px] text-stone-400 mt-0.5">Step-by-step assembly guide · EU &amp; UK markets</div>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <span class="bg-amber-50 text-amber-700 border border-amber-100 rounded-md px-2 py-0.5 font-medium">Assembly</span>
                </td>
                <td class="px-4 py-3 tabular">
                  <div class="flex gap-1 flex-wrap">
                    <span class="bg-stone-100 text-stone-600 rounded-md px-1.5 py-0.5">30317</span>
                    <span class="bg-stone-100 text-stone-600 rounded-md px-1.5 py-0.5">30318</span>
                  </div>
                </td>
                <td class="px-4 py-3 tabular font-medium text-stone-700">v3.1</td>
                <td class="px-4 py-3">
                  <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-md px-2 py-0.5 font-medium">
                    <i class="ti ti-circle-check text-xs"></i> Approved
                  </span>
                </td>
                <td class="px-4 py-3 text-stone-600">Anja H.</td>
                <td class="px-4 py-3 tabular text-stone-500">14 Mar 2025</td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1">
                    <button class="px-2 py-1 text-[11px] font-medium text-brand-600 hover:bg-brand-50 rounded-md transition-colors">View</button>
                    <button class="px-2 py-1 text-[11px] font-medium text-stone-600 hover:bg-stone-100 rounded-md transition-colors flex items-center gap-1"><i class="ti ti-download text-xs"></i> Download</button>
                  </div>
                </td>
              </tr>

              <!-- Row 2: Care Guide Leather Upholstery -->
              <tr class="hover:bg-stone-50 transition-colors cursor-pointer" onclick="selectRow(this)">
                <td class="px-4 py-3"><input type="checkbox" class="rounded border-black/20 w-3.5 h-3.5"></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2.5">
                    <div class="w-7 h-7 rounded-lg bg-brand-50 flex items-center justify-center shrink-0">
                      <i class="ti ti-file-text text-sm text-brand-600"></i>
                    </div>
                    <div>
                      <div class="font-medium text-stone-800">Care Guide — Full-Grain Leather Upholstery</div>
                      <div class="text-[11px] text-stone-400 mt-0.5">Cleaning &amp; maintenance guide for leather seating</div>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <span class="bg-indigo-50 text-indigo-700 border border-indigo-100 rounded-md px-2 py-0.5 font-medium">Care Guide</span>
                </td>
                <td class="px-4 py-3 tabular">
                  <span class="bg-stone-100 text-stone-600 rounded-md px-1.5 py-0.5">30317</span>
                </td>
                <td class="px-4 py-3 tabular font-medium text-stone-700">v2.0</td>
                <td class="px-4 py-3">
                  <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-md px-2 py-0.5 font-medium">
                    <i class="ti ti-circle-check text-xs"></i> Approved
                  </span>
                </td>
                <td class="px-4 py-3 text-stone-600">Erik O.</td>
                <td class="px-4 py-3 tabular text-stone-500">10 Mar 2025</td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1">
                    <button class="px-2 py-1 text-[11px] font-medium text-brand-600 hover:bg-brand-50 rounded-md transition-colors">View</button>
                    <button class="px-2 py-1 text-[11px] font-medium text-stone-600 hover:bg-stone-100 rounded-md transition-colors flex items-center gap-1"><i class="ti ti-download text-xs"></i> Download</button>
                  </div>
                </td>
              </tr>

              <!-- Row 3: Technical Datasheet Nordic Shelf — IN REVIEW (selected) -->
              <tr id="row-datasheet-nordic" class="bg-brand-50/50 border-l-2 border-brand-600 cursor-pointer hover:bg-brand-50 transition-colors" onclick="selectRow(this)">
                <td class="px-4 py-3"><input type="checkbox" class="rounded border-black/20 w-3.5 h-3.5" checked></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2.5">
                    <div class="w-7 h-7 rounded-lg bg-cyan-50 flex items-center justify-center shrink-0">
                      <i class="ti ti-file-description text-sm text-cyan-600"></i>
                    </div>
                    <div>
                      <div class="font-medium text-stone-800 flex items-center gap-1.5">
                        Technical Datasheet — Nordvik Archive Shelf
                        <span class="w-1.5 h-1.5 rounded-full bg-brand-600 pulse-dot inline-block"></span>
                      </div>
                      <div class="text-[11px] text-stone-400 mt-0.5">Load capacity, dimensions &amp; material specs</div>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <span class="bg-cyan-50 text-cyan-700 border border-cyan-100 rounded-md px-2 py-0.5 font-medium">Datasheet</span>
                </td>
                <td class="px-4 py-3 tabular">
                  <div class="flex gap-1 flex-wrap">
                    <span class="bg-stone-100 text-stone-600 rounded-md px-1.5 py-0.5">30401–30404</span>
                  </div>
                </td>
                <td class="px-4 py-3 tabular font-medium text-stone-700">v1.4</td>
                <td class="px-4 py-3">
                  <span class="inline-flex items-center gap-1 bg-brand-50 text-brand-600 border border-brand-100 rounded-md px-2 py-0.5 font-medium">
                    <i class="ti ti-eye text-xs"></i> In Review
                  </span>
                </td>
                <td class="px-4 py-3 text-stone-600">Anja H.</td>
                <td class="px-4 py-3 tabular text-stone-500">08 Mar 2025</td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1">
                    <button class="px-2 py-1 text-[11px] font-medium text-brand-600 bg-brand-50 border border-brand-100 hover:bg-brand-100 rounded-md transition-colors">Review</button>
                    <button class="px-2 py-1 text-[11px] font-medium text-emerald-700 bg-emerald-50 border border-emerald-100 hover:bg-emerald-100 rounded-md transition-colors">Approve</button>
                  </div>
                </td>
              </tr>

              <!-- Row 4: BOM Forma Lounge Chair -->
              <tr class="hover:bg-stone-50 transition-colors cursor-pointer" onclick="selectRow(this)">
                <td class="px-4 py-3"><input type="checkbox" class="rounded border-black/20 w-3.5 h-3.5"></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2.5">
                    <div class="w-7 h-7 rounded-lg bg-violet-50 flex items-center justify-center shrink-0">
                      <i class="ti ti-list-details text-sm text-violet-600"></i>
                    </div>
                    <div>
