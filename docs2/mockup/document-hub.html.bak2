<script>
  function setTab(el, tab) {
    document.querySelectorAll('.tab-btn').forEach(function(btn) {
      btn.classList.remove('bg-brand-600', 'text-white');
      btn.classList.add('text-stone-500');
    });
    el.classList.add('bg-brand-600', 'text-white');
    el.classList.remove('text-stone-500');
  }

  function selectRow(row) {
    document.querySelectorAll('tbody tr').forEach(function(r) {
      r.classList.remove('bg-brand-50/50', 'border-l-2', 'border-brand-600');
    });
    row.classList.add('bg-brand-50/50', 'border-l-2', 'border-brand-600');
  }

  function toggleHistory() {
    var el = document.getElementById('version-history');
    var chevron = document.getElementById('history-chevron');
    el.classList.toggle('hidden');
    chevron.style.transform = el.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
  }
</script>

