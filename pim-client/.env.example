# PIM API (.NET 8)
VITE_API_URL=https://localhost:7082/api

# Auth API (shared res-auth-api)
VITE_API_AUTH=https://api-auth.local.com
VITE_API_AUTHZ=https://api-auth.local.com/api

# Azure AD app registration
VITE_TENANT_ID=your-tenant-id
VITE_CLIENT_ID=your-client-id

# Shared API key (from res-auth-api config)
VITE_X_API_KEY=your-x-api-key

# App code used in Azure AD state param
VITE_API_APP=PimApi

# Default role name (leave empty to use server default)
VITE_DEFAULT_ROLE_NAME=

# OAuth redirect URI — must match res-auth-api CORS + Azure AD app registration
VITE_REDIRECT_URI=https://pim.local.com:3001/auth-callback
VITE_USE_SSL=true

# Feature flags
VITE_USE_MOCK=false
VITE_ENABLE_NOTIFICATION_SIGNALR=false

# D365 F&O OData (read-only sync source)
VITE_D365_BASE_URL=https://responsevn.operations.dynamics.com
